{
  "manifest_version": 3,
  "name": "Adaptive Form Filler Agent",
  "version": "0.1.0",
  "description": "Rule-first form filler with local memory and bounded AI fallback hooks.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "notifications",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Adaptive Form Filler",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_popup": "src/popup/popup.html"
  },
  "options_page": "src/experiment-runner/experiment-runner.html",
  "web_accessible_resources": [
    {
      "resources": ["src/applicant-data/profile-defaults.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/browser-capture/aria-snapshot/string-utils.js",
        "src/browser-capture/aria-snapshot/yaml-utils.js",
        "src/browser-capture/aria-snapshot/dom-utils.js",
        "src/browser-capture/aria-snapshot/role-utils.js",
        "src/browser-capture/aria-snapshot/accname.js",
        "src/browser-capture/aria-snapshot/aria-snapshot.js",
        "src/browser-capture/browser-tools.js",
        "src/field-guessing/profile-field-catalog.js",
        "src/field-learning/learned-field-memory.js",
        "src/field-filling/demographic-field-tools.js",
        "src/field-filling/field-descriptor-tools.js",
        "src/field-filling/control-fill-tools.js",
        "src/field-filling/choice-control-tools.js",
        "src/field-filling/page-fill-engine.js",
        "src/field-learning/field-learning-listeners.js",
        "src/field-filling/page-form-detection.js",
        "src/field-extraction/scan-result-adapters.js",
        "src/experiment-runner/extracted-field-cards-view.js",
        "src/floating-bar/floating-bar-ui.js",
        "src/floating-bar/large-textbox-assist-ui.js",
        "src/floating-bar/floating-bar-controller.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
